library(readxl)
library(dplyr)
library(purrr)
library(stringr)
#list data links found here: https://www.azdhs.gov/preparedness/epidemiology-disease-control/immunization/index.php#reports-immunization-coverage
excel_urls <- c(
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2024-2025/2024-arizona-reporting-schools-coverage.xlsx?v=20250522",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2023-2024/2023-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2022-2023/2022-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2021-2022/2021-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2020-2021/2020-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2019-2020/2019-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2018-2019/2018-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2017-2018/2017-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2016-2017/2016-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2015-2016-arizona-reporting-schools-coverage.xlsx"
)
#create temporary directory
temp_dir <- tempdir()
#read all sheets in each file
read_all_sheets <- function(url) {
file_name <- file.path(temp_dir, basename(url))
download.file(url, file_name, mode = "wb")
sheets <- excel_sheets(file_name)
#extract year from link
year_range <- str_extract(url, "\\d{4}-\\d{4}")
start_year <- str_sub(year_range, 1, 4)
data <- map_df(sheets, ~ read_excel(file_name, sheet = .x, col_types = "text") %>%
mutate(sheet_name = .x,
file = basename(url),
year = start_year))  # This adds the extracted year to each row
return(data)
}
all_data <- map_df(excel_urls, read_all_sheets)
library(readxl)
library(dplyr)
library(purrr)
library(stringr)
#list data links found here: https://www.azdhs.gov/preparedness/epidemiology-disease-control/immunization/index.php#reports-immunization-coverage
excel_urls <- c(
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2024-2025/2024-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2023-2024/2023-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2022-2023/2022-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2021-2022/2021-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2020-2021/2020-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2019-2020/2019-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2018-2019/2018-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2017-2018/2017-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2016-2017/2016-arizona-reporting-schools-coverage.xlsx",
"https://www.azdhs.gov/documents/preparedness/epidemiology-disease-control/immunization/statistics-reports/2015-2016-arizona-reporting-schools-coverage.xlsx"
)
#create temporary directory
temp_dir <- tempdir()
#read all sheets in each file
read_all_sheets <- function(url) {
file_name <- file.path(temp_dir, basename(url))
download.file(url, file_name, mode = "wb")
sheets <- excel_sheets(file_name)
#extract year from link
year_range <- str_extract(url, "\\d{4}-\\d{4}")
start_year <- str_sub(year_range, 1, 4)
data <- map_df(sheets, ~ read_excel(file_name, sheet = .x, col_types = "text") %>%
mutate(sheet_name = .x,
file = basename(url),
year = start_year))  # This adds the extracted year to each row
return(data)
}
all_data <- map_df(excel_urls, read_all_sheets)
# Clean names
clean_names <- function(x) {
x %>%
str_replace_all("%", "PCT") %>%
str_replace_all("[^A-Za-z0-9]", "_") %>%
str_replace_all("_+", "_") %>%
str_trim() %>%
str_to_upper()
}
# Apply cleaned names
names(all_data) <- clean_names(names(all_data))
# Get rid of duplicate cols
colnames(all_data) <- make.unique(names(all_data))
#merge all the data together
df <- all_data %>%
mutate(
SCHOOL_NAME_ = coalesce(SCHOOL_NAME, SCHOOL_NAME.1),
PCT_MEDICAL_EXEMPT_ = coalesce(PCT_MEDICAL_EXEMPT, PCT_MEDICAL_EXEMPT.1),
ADDRESS_ = coalesce(ADDRESS_1, ADDRESS, SCHOOL_ADDRESS, SCHOOL_ADDRESS_ONE),
ZIP_ = coalesce(ZIP, ZIP_CODE),
ENROLLED_ = coalesce(ENROLLED, ENROLLEDCOUNT, ENROLLED2),
PCT_IMMUNE_MMR_ = coalesce(PCT_IMMUNE_MMR, PCT_IMMUNE_MMR.1),
PCT_COMPLIANCE_MMR_ = coalesce(PCT_COMPLIANCE_MMR, PCT_COMPLIANCE_MMR.1),
PCT_EXEMPT_MMR_ = coalesce(PCT_EXEMPT_MMR, PCT_EXEMPT_MMR.1),
PCT_MEDICAL_EXEMPT_ = coalesce(PCT_MEDICAL_EXEMPT, PCT_MEDICAL_EXEMPT.1)
) %>%
select(
SCHOOL_NAME_, YEAR, SHEET_NAME, ADDRESS_, ZIP_, ENROLLED_, COUNTY, CITY,
PCT_IMMUNE_MMR_, PCT_COMPLIANCE_MMR_, PCT_EXEMPT_MMR_, PCT_MEDICAL_EXEMPT_
)
#filter out missing school name data
df_clean <- df %>%
filter(SCHOOL_NAME_ != " ", !is.na(SCHOOL_NAME_))
#export
write.csv(df_clean, 'C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/Exemptions.csv')
source("~/MB Projects/Measles/CORIscrape.R")
# Load required libraries
library(taskscheduleR)      # For scheduling R scripts on Windows
library(arcgislayers)       # For reading ArcGIS feature services
library(dplyr)              # For data manipulation
library(sf)                 # For handling spatial data
library(readr)              # For reading and writing CSVs
library(tibble)             # For creating tidy data frames
# --- Load case data from ArcGIS online feature service ---
url <- "https://services1.arcgis.com/0MSEUqKaxRlEPj5g/arcgis/rest/services/Measles%20Cases%20and%20MMR%20Coverage/FeatureServer/0"
casedata <- arc_read(url)  # Read feature layer into R
# Check for invalid geometries and fix them
invalid_geometries <- st_is_valid(casedata)
casedata <- st_make_valid(casedata)
# --- Summarize today’s cases by state and county ---
todays_cases <- casedata %>%
group_by(STATE_NAME, NAME) %>%
summarize(total_cases = sum(F2025_Measles_Cases, na.rm = TRUE)) %>%
arrange(STATE_NAME, NAME) %>%
filter(total_cases > 0)  # Keep only counties with >0 cases
# --- Load yesterday’s case data ---
yesterday <- Sys.Date() - 1
date_string <- format(yesterday, "%Y-%m-%d")
file_path <- paste0("C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/Scrape/", date_string, ".csv")
yesterdays_cases <- read.csv(file_path)
# Summarize yesterday’s cases similarly
yesterdays_cases <- yesterdays_cases %>%
group_by(STATE_NAME, NAME) %>%
summarize(total_cases = sum(F2025_Measles_Cases, na.rm = TRUE), .groups = "drop") %>%
arrange(STATE_NAME, NAME) %>%
filter(total_cases > 0)
# --- Load timeseries of measles cases ---
measles_ts <- read.csv("C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/measles_ts.csv")
# --- Compute difference in cases since yesterday ---
case_diff <- todays_cases %>%
st_drop_geometry() %>%
left_join(yesterdays_cases, by = c("STATE_NAME", "NAME"), suffix = c("_today", "_yesterday")) %>%
mutate(
total_cases_yesterday = ifelse(is.na(total_cases_yesterday), 0, total_cases_yesterday),
F2025_Measles_Cases = total_cases_today - total_cases_yesterday
) %>%
filter(F2025_Measles_Cases > 0) %>%
select(STATE_NAME, NAME, F2025_Measles_Cases) %>%
mutate(Date = format(Sys.Date(), "%Y-%m-%d"))
# --- Avoid duplicate case entries for the same day ---
case_diff <- case_diff %>%
anti_join(
measles_ts %>% filter(Date == format(Sys.Date(), "%Y-%m-%d")),
by = c("STATE_NAME", "NAME", "Date")
)
# --- Append new case records ---
if (nrow(case_diff) > 0) {
measles_ts_updated <- bind_rows(measles_ts, case_diff)
} else {
measles_ts_updated <- measles_ts
}
# Add OBJECTID to the updated timeseries
measles_ts_updated <- measles_ts_updated %>%
mutate(OBJECTID = row_number())
# Save updated timeseries
write.csv(measles_ts_updated, "C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/measles_ts.csv", row.names = FALSE)
# --- Merge timeseries with cleaned county-level info ---
# Get 1 row per county with attributes (no geometry)
county_info <- casedata %>%
st_drop_geometry() %>%
select(STATE_NAME, NAME, STATE_ABBR, STATE_FIPS, COUNTY_FIPS, FIPS, POPULATION, POP_SQMI, SQMI, MMR_Coverage, Related_to_Outbreak) %>%
distinct(STATE_NAME, NAME, .keep_all = TRUE)
# Merge minimal attributes
measles <- measles_ts_updated %>%
left_join(county_info, by = c("STATE_NAME", "NAME")) %>%
left_join(
st_drop_geometry(casedata) %>% select(STATE_NAME, NAME) %>% distinct(),
by = c("STATE_NAME", "NAME")
) %>%
rename(
State = STATE_NAME,
County = NAME,
Cases = F2025_Measles_Cases,
Report_Date = Date
) %>%
distinct(State, County, Report_Date, .keep_all = TRUE) %>%
mutate(OBJECTID = row_number())
# Save the cleaned measles case file
write_csv(measles, "C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/USMeaslesCases.csv")
# --- Save today’s raw case data snapshot ---
filename <- paste0(Sys.Date(), ".csv")
full_path <- file.path("C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/Scrape", filename)
write_csv(casedata, full_path)
# --- Prepare measles death data manually ---
deaths <- casedata %>%
filter(Confirmed_Deaths > 0)
measles_deaths <- tribble(
~STATE_NAME,    ~NAME,            ~death_date,  ~decedent_info,                           ~notes,
"Texas",        "Lubbock County", "2025-02-26", "6-year-old unvaccinated girl",            "Pneumonia complications after 3 weeks of illness",
"Texas",        "Lubbock County", "2025-04-03", "8-year-old unvaccinated girl",            "Pulmonary failure; no underlying conditions",
"New Mexico",   "Lea County",     "2025-03-06", "Unvaccinated adult",                      "Did not seek medical care prior to death"
) %>%
mutate(death_date = as.Date(death_date))
# Merge with spatial/deep attribute data
measles_deaths <- merge(measles_deaths, deaths, c("STATE_NAME", "NAME"))
# Select and rename fields for export
measles_deaths <- measles_deaths %>%
rename(
State = STATE_NAME,
County = NAME
) %>%
select(State, County, death_date, decedent_info, notes, STATE_ABBR, STATE_FIPS, COUNTY_FIPS, FIPS, POPULATION, POP_SQMI, SQMI, MMR_Coverage, Related_to_Outbreak, geometry) %>%
mutate(OBJECTID = row_number())
# Save death data
write_csv(measles_deaths, "C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/USMeaslesDeaths.csv")
# --- Read exposure data from second ArcGIS service ---
url2 <- "https://services1.arcgis.com/0MSEUqKaxRlEPj5g/arcgis/rest/services/2025_Measles_Cases_and_Exposures(Exposure_Tracking)_(3)/FeatureServer/0"
exposuredata <- arc_read(url2)
# Fix geometries if needed
invalid_geometries <- st_is_valid(exposuredata)
exposuredata <- st_make_valid(exposuredata)
# Add OBJECTID to exposure dataset
exposuredata <- exposuredata %>%
mutate(OBJECTID = row_number())
# Save exposure data
write_csv(exposuredata, "C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/Exposures.csv")
# --- GitHub Automation ---
# Define local GitHub repo path
repo_path <- "C:/Users/mmcalend/Documents/GitHub/measles-data"
# Define full source paths
cases_src <- "C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/USMeaslesCases.csv"
deaths_src <- "C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/USMeaslesDeaths.csv"
exposures_src <- "C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/Exposures.csv"
# Define destination paths
cases_dst <- file.path(repo_path, "USMeaslesCases.csv")
deaths_dst <- file.path(repo_path, "USMeaslesDeaths.csv")
exposures_dst <- file.path(repo_path, "Exposures.csv")
# Copy all 3 files to the repo
file.copy(cases_src, cases_dst, overwrite = TRUE)
file.copy(deaths_src, deaths_dst, overwrite = TRUE)
file.copy(exposures_src, exposures_dst, overwrite = TRUE)
# Commit and push to GitHub
system(paste("cd", repo_path, "&& git add USMeaslesCases.csv USMeaslesDeaths.csv Exposures.csv"))
system(paste("cd", repo_path, sprintf('&& git commit -m "Daily update: %s"', Sys.Date())))
system(paste("cd", repo_path, "&& git push"))
# --- GitHub Automation ---
# Define local GitHub repo path
repo_path <- "C:/Users/mmcalend/Documents/GitHub/measles-data"
