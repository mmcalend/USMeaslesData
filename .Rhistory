mutate(Date = format(Sys.Date(), "%Y-%m-%d"))
# --- Avoid duplicate case entries for the same day ---
case_diff <- case_diff %>%
anti_join(
measles_ts %>% filter(Date == format(Sys.Date(), "%Y-%m-%d")),
by = c("STATE_NAME", "NAME", "Date")
)
# --- Append new case records ---
if (nrow(case_diff) > 0) {
measles_ts_updated <- bind_rows(measles_ts, case_diff)
} else {
measles_ts_updated <- measles_ts
}
# Add OBJECTID to the updated timeseries
measles_ts_updated <- measles_ts_updated %>%
mutate(OBJECTID = row_number())
# Save updated timeseries
write.csv(measles_ts_updated, "C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/measles_ts.csv", row.names = FALSE)
# --- Merge timeseries with cleaned county-level info ---
# Get 1 row per county with attributes (no geometry)
county_info <- casedata %>%
st_drop_geometry() %>%
select(STATE_NAME, NAME, STATE_ABBR, STATE_FIPS, COUNTY_FIPS, FIPS, POPULATION, POP_SQMI, SQMI, MMR_Coverage, Related_to_Outbreak) %>%
distinct(STATE_NAME, NAME, .keep_all = TRUE)
# Merge minimal attributes
measles <- measles_ts_updated %>%
left_join(county_info, by = c("STATE_NAME", "NAME")) %>%
left_join(
st_drop_geometry(casedata) %>% select(STATE_NAME, NAME) %>% distinct(),
by = c("STATE_NAME", "NAME")
) %>%
rename(
State = STATE_NAME,
County = NAME,
Cases = F2025_Measles_Cases,
Report_Date = Date
) %>%
distinct(State, County, Report_Date, .keep_all = TRUE) %>%
mutate(OBJECTID = row_number())
# Save the cleaned measles case file
write_csv(measles, "C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/USMeaslesCases.csv")
# --- Save today’s raw case data snapshot ---
filename <- paste0(Sys.Date(), ".csv")
full_path <- file.path("C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/Scrape", filename)
write_csv(casedata, full_path)
# --- Prepare measles death data manually ---
deaths <- casedata %>%
filter(Confirmed_Deaths > 0)
measles_deaths <- tribble(
~STATE_NAME,    ~NAME,            ~death_date,  ~decedent_info,                           ~notes,
"Texas",        "Lubbock County", "2025-02-26", "6-year-old unvaccinated girl",            "Pneumonia complications after 3 weeks of illness",
"Texas",        "Lubbock County", "2025-04-03", "8-year-old unvaccinated girl",            "Pulmonary failure; no underlying conditions",
"New Mexico",   "Lea County",     "2025-03-06", "Unvaccinated adult",                      "Did not seek medical care prior to death"
) %>%
mutate(death_date = as.Date(death_date))
# Merge with spatial/deep attribute data
measles_deaths <- merge(measles_deaths, deaths, c("STATE_NAME", "NAME"))
# Select and rename fields for export
measles_deaths <- measles_deaths %>%
rename(
State = STATE_NAME,
County = NAME
) %>%
select(State, County, death_date, decedent_info, notes, STATE_ABBR, STATE_FIPS, COUNTY_FIPS, FIPS, POPULATION, POP_SQMI, SQMI, MMR_Coverage, Related_to_Outbreak, geometry) %>%
mutate(OBJECTID = row_number())
# Save death data
write_csv(measles_deaths, "C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/USMeaslesDeaths.csv")
# --- Read exposure data from second ArcGIS service ---
url2 <- "https://services1.arcgis.com/0MSEUqKaxRlEPj5g/arcgis/rest/services/2025_Measles_Cases_and_Exposures(Exposure_Tracking)_(3)/FeatureServer/0"
exposuredata <- arc_read(url2)
# Fix geometries if needed
invalid_geometries <- st_is_valid(exposuredata)
exposuredata <- st_make_valid(exposuredata)
# Add OBJECTID to exposure dataset
exposuredata <- exposuredata %>%
mutate(OBJECTID = row_number())
# Save exposure data
write_csv(exposuredata, "C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/Exposures.csv")
# --- GitHub Automation (Fixed) ---
# Set working directory
setwd(repo_path)
# Add files to staging
system2("git", args = c("add", "USMeaslesCases.csv", "USMeaslesDeaths.csv", "Exposures.csv"))
# Commit (quote the message to avoid split)
commit_msg <- sprintf("Daily update: %s", Sys.Date())
system2("git", args = c("commit", "-m", shQuote(commit_msg)))
# Pull first (in case of non-fast-forward)
system2("git", args = c("pull", "--rebase"))
# Then push
system2("git", args = c("push"))
library(taskscheduleR)
taskscheduler_create(
taskname = "DailyMeaslesUpdate",  # Friendly name
rscript = "C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/CORIScrape.R",
schedule = "DAILY",
starttime = "17:00",  # Change to your preferred time (24h format, e.g., "20:30")
