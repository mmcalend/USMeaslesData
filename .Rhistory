cases_src <- "C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/USMeaslesCases.csv"
deaths_src <- "C:/Users/mmcalend/ASU Dropbox/Meaghan Batchelor/PC/Documents/MB Projects/Measles/USMeaslesDeaths.csv"
